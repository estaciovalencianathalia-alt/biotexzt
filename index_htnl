import React, { useState, useEffect, useRef } from 'react';
import { 
  Leaf, 
  Search, 
  Send, 
  Volume2, 
  VolumeX, 
  Mic, 
  MicOff, 
  BookOpen, 
  Compass, 
  Award, 
  RotateCcw, 
  HelpCircle, 
  Sliders, 
  Sparkles, 
  ChevronRight, 
  CheckCircle2, 
  BookMarked,
  Info
} from 'lucide-react';

// --- CONFIGURACIÓN DE FIREBASE Y DE GEMINI ---
const apiKey = ""; // La clave de API se inyecta dinámicamente en tiempo de ejecución
const modelName = "gemini-2.5-flash-preview-09-2025";
const ttsModelName = "gemini-2.5-flash-preview-tts";

// Definición de ramas biológicas para consultas rápidas
const BIOLOGY_BRANCHES = [
  { id: 'mol', name: 'Biología Celular y Molecular', icon: '🧬', prompt: 'Explícame el proceso de transcripción del ADN y la síntesis de ARN mensajero.' },
  { id: 'gen', name: 'Genética y Herencia', icon: '🌱', prompt: '¿Cuáles son las leyes de Mendel y cómo explican la segregación de caracteres?' },
  { id: 'eco', name: 'Ecología y Ecosistemas', icon: '🌍', prompt: 'Explica el flujo de energía y los niveles tróficos en un ecosistema terrestre.' },
  { id: 'evo', name: 'Evolución y Adaptación', icon: '🦎', prompt: '¿Qué es la selección natural y cómo difiere de la deriva genética?' },
  { id: 'mic', name: 'Microbiología y Virología', icon: '🧫', prompt: '¿Cuál es la diferencia estructural y funcional entre un virus bacteriófago y una bacteria?' },
  { id: 'mar', name: 'Biología Marina', icon: '🐙', prompt: 'Describe las adaptaciones biológicas de las especies abisales a las altas presiones y falta de luz.' }
];

// Ecosistemas decorativos / Temas visuales
const ECOSYSTEMS = [
  { id: 'rainforest', name: 'Selva Tropical', class: 'from-emerald-950 via-teal-900 to-stone-900', accent: '#1B5E20' },
  { id: 'ocean', name: 'Océano Profundo', class: 'from-blue-950 via-indigo-950 to-slate-900', accent: '#1565C0' },
  { id: 'autumn', name: 'Bosque Templado', class: 'from-amber-950 via-amber-900 to-stone-900', accent: '#6D4C41' },
  { id: 'light', name: 'Laboratorio Claro', class: 'from-emerald-50 via-teal-50 to-stone-100 text-stone-900', accent: '#4CAF50' }
];

export default function App() {
  // --- ESTADO ---
  const [messages, setMessages] = useState([
    {
      id: 'welcome',
      role: 'assistant',
      text: "¡Saludos, colega o entusiasta de la ciencia! Soy **BioMentor AI**, tu guía y tutor académico en el maravilloso reino de la biología. Estoy aquí para asistirte en tus investigaciones, aclarar dudas complejas o evaluar tus conocimientos con el rigor y la pasión de un veterano profesor de universidad. ¿Qué área de la vida deseas explorar o investigar hoy?",
      timestamp: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }),
      level: 'normal'
    }
  ]);
  const [inputText, setInputText] = useState("");
  const [isLoading, setIsLoading] = useState(false);
  const [responseLevel, setResponseLevel] = useState("normal"); // 'brief', 'normal', 'detailed'
  const [currentEcosystem, setCurrentEcosystem] = useState(ECOSYSTEMS[0]);
  const [isLightMode, setIsLightMode] = useState(false);
  const [isListening, setIsListening] = useState(false);
  const [speechSupported, setSpeechSupported] = useState(false);
  const [audioPlaying, setAudioPlaying] = useState(false);
  const [activeTab, setActiveTab] = useState('chat'); // 'chat' | 'library' | 'feedback'
  
  // Retroalimentación extraída del último mensaje
  const [extractedQuiz, setExtractedQuiz] = useState({
    summary: [
      "La biología es el estudio científico de la vida y los organismos.",
      "BioMentor proporciona explicaciones precisas basadas en ciencia rigurosa.",
      "Puedes elegir entre respuestas breves, normales o sumamente detalladas."
    ],
    question: "¿Qué rama de la biología te interesa investigar hoy para poner a prueba mis conocimientos?",
    userAnswer: "",
    quizFeedback: null
  });

  const messagesEndRef = useRef(null);
  const audioRef = useRef(null);

  // --- EFECTOS ---
  useEffect(() => {
    scrollToBottom();
  }, [messages]);

  useEffect(() => {
    // Comprobar soporte de reconocimiento de voz del navegador
    if (typeof window !== 'undefined') {
      const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
      if (SpeechRecognition) {
        setSpeechSupported(true);
      }
    }
  }, []);

  const scrollToBottom = () => {
    messagesEndRef.current?.scrollIntoView({ behavior: 'smooth' });
  };

  // --- LLAMADA A LA API DE GEMINI CON EXPONENTIAL BACKOFF ---
  const callGeminiAPI = async (promptText, systemInstruction, retries = 5, delay = 1000) => {
    const url = `https://generativelanguage.googleapis.com/v1beta/models/${modelName}:generateContent?key=${apiKey}`;
    
    const payload = {
      contents: [{ parts: [{ text: promptText }] }],
      systemInstruction: { parts: [{ text: systemInstruction }] }
    };

    for (let i = 0; i < retries; i++) {
      try {
        const response = await fetch(url, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });

        if (!response.ok) {
          throw new Error(`HTTP error! status: ${response.status}`);
        }

        const data = await response.json();
        const text = data.candidates?.[0]?.content?.parts?.[0]?.text;
        if (text) return text;
        throw new Error("Respuesta de API vacía");
      } catch (error) {
        if (i === retries - 1) throw error;
        await new Promise(resolve => setTimeout(resolve, delay));
        delay *= 2; // Backoff exponencial
      }
    }
  };

  // --- INTRODUCCIÓN DE LA IDENTIDAD DE BIOMENTOR AI (SYSTEM INSTRUCTION) ---
  const getSystemInstruction = () => {
    const levelInstructions = {
      brief: "Responde de forma sumamente BREVE, directa al grano, máximo 5 líneas totales.",
      normal: "Responde de manera NORMAL. Una explicación concreta, clara y directa al tema, ideal para lectura rápida.",
      detailed: "Responde de manera DETALLADA. Estructura tu respuesta con títulos utilizando Markdown: 1. Definición formal, 2. Procesos biológicos involucrados paso a paso, 3. Ejemplos ilustrativos del mundo real, 4. Aplicaciones científicas/industriales prácticas, y 5. Referencias bibliográficas sugeridas (autores o revistas de prestigio)."
    };

    return `
Eres BioMentor AI, un prestigioso y entrañable profesor universitario de biología de 60 años de edad, con voz grave, docta y sabia.
Tu misión es resolver cualquier inquietud de investigación biológica con máximo rigor científico, lenguaje profesional pero sumamente didáctico y alentador.

INSTRUCCIÓN DE LONGITUD DE RESPUESTA:
${levelInstructions[responseLevel]}

REQUISITO OBLIGATORIO DE RETROALIMENTACIÓN FINAL:
Al final de CADA una de tus respuestas (sin importar el nivel de detalle seleccionado), debes incluir EXACTAMENTE una sección de retroalimentación estructurada con la siguiente sintaxis estricta al final para que la app pueda parsearla:

---RETROALIMENTACION---
[Resumen: Escribe entre 2 y 3 viñetas breves con los puntos clave de tu respuesta]
[Pregunta: Formula exactamente una pregunta conceptual para evaluar si el usuario entendió el tema explicado]
---FIN---

Ejemplo de esta sección obligatoria al final:
---RETROALIMENTACION---
• La mitosis produce dos células hijas idénticas a partir de una célula madre.
• Consiste en cuatro etapas consecutivas: profase, metafase, anafase y telofase.
¿En qué fase de la mitosis se alinean los cromosomas de manera exacta en la placa ecuatorial de la célula?
---FIN---

Mantén siempre el tono amable, profesional, riguroso y apasionado por la naturaleza.
`;
  };

  // --- ENVÍO DE MENSAJES Y PROCESAMIENTO ---
  const handleSendMessage = async (textToSend = inputText) => {
    if (!textToSend.trim() || isLoading) return;

    const userMessage = {
      id: Date.now().toString(),
      role: 'user',
      text: textToSend,
      timestamp: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }),
      level: responseLevel
    };

    setMessages(prev => [...prev, userMessage]);
    setInputText("");
    setIsLoading(true);

    try {
      const responseText = await callGeminiAPI(textToSend, getSystemInstruction());
      
      // Separar el contenido didáctico de la sección de retroalimentación estructurada
      let cleanText = responseText;
      let summaryPoints = [];
      let feedbackQuestion = "";

      const retroMatch = responseText.match(/---RETROALIMENTACION---([\s\S]*?)---FIN---/);
      if (retroMatch) {
        cleanText = responseText.replace(/---RETROALIMENTACION---[\s\S]*?---FIN---/, '').trim();
        const rawRetroContent = retroMatch[1];
        
        // Parsear puntos clave y preguntas
        const lines = rawRetroContent.split('\n').map(l => l.trim()).filter(Boolean);
        lines.forEach(line => {
          if (line.startsWith('•') || line.startsWith('-') || line.startsWith('*')) {
            summaryPoints.push(line.replace(/^[•\-*]\s*/, ''));
          } else if (line.includes('?') || line.startsWith('¿')) {
            feedbackQuestion = line;
          } else if (line.length > 10 && summaryPoints.length < 3 && !feedbackQuestion) {
            summaryPoints.push(line);
          }
        });
      }

      const aiMessage = {
        id: (Date.now() + 1).toString(),
        role: 'assistant',
        text: cleanText,
        timestamp: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }),
        level: responseLevel,
        quiz: {
          summary: summaryPoints.length > 0 ? summaryPoints : ["Consistencia conceptual analizada correctamente."],
          question: feedbackQuestion || "¿Tienes alguna duda sobre este proceso biológico?"
        }
      };

      setMessages(prev => [...prev, aiMessage]);

      // Actualizar el panel de control de retroalimentación actual
      if (aiMessage.quiz) {
        setExtractedQuiz({
          summary: aiMessage.quiz.summary,
          question: aiMessage.quiz.question,
          userAnswer: "",
          quizFeedback: null
        });
      }

      // Desencadenar opcionalmente una lectura automática del texto mediante voz
      speakText(cleanText.replace(/[#*`_]/g, '').substring(0, 300) + "..."); // Limpiamos markdown para la lectura

    } catch (error) {
      console.error(error);
      setMessages(prev => [...prev, {
        id: (Date.now() + 1).toString(),
        role: 'assistant',
        text: "Mis disculpas, investigador. Parece que he tenido una pequeña interferencia en mis canales de transmisión de datos. Por favor, reformula tu pregunta o intentémoslo una vez más.",
        timestamp: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })
      }]);
    } finally {
      setIsLoading(false);
    }
  };

  // --- SÍNTESIS DE VOZ (TTS) ---
  const speakText = async (textToSpeak) => {
    if (!textToSpeak) return;

    // Intentamos primero con la API experimental de Gemini TTS si está disponible y configurada,
    // de lo contrario usamos la API nativa de Síntesis del Navegador (Web Speech API).
    if (apiKey) {
      try {
        setAudioPlaying(true);
        const url = `https://generativelanguage.googleapis.com/v1beta/models/${ttsModelName}:generateContent?key=${apiKey}`;
        const payload = {
          contents: [{ parts: [{ text: `Di con tono cálido, pausado, voz grave de profesor sabio de 60 años: ${textToSpeak}` }] }],
          generationConfig: { 
            responseModalities: ["AUDIO"], 
            speechConfig: { 
              voiceConfig: { 
                prebuiltVoiceConfig: { voiceName: "Fenrir" } // Usamos Fenrir como voz madura y grave
              } 
            } 
          },
          model: ttsModelName
        };

        const response = await fetch(url, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });

        if (response.ok) {
          const result = await response.json();
          const audioInline = result.candidates?.[0]?.content?.parts?.[0]?.inlineData;
          if (audioInline && audioInline.data) {
            // Conversión del PCM de Gemini a WAV para reproducción
            const pcmBase64 = audioInline.data;
            const pcmBinary = atob(pcmBase64);
            const pcmArray = new Uint8Array(pcmBinary.length);
            for (let i = 0; i < pcmBinary.length; i++) {
              pcmArray[i] = pcmBinary.charCodeAt(i);
            }
            
            // Suponemos tasa estándar del modelo de 24000Hz o similar
            const wavBlob = pcmToWav(pcmArray.buffer, 24000);
            const audioUrl = URL.createObjectURL(wavBlob);
            
            if (audioRef.current) {
              audioRef.current.src = audioUrl;
              audioRef.current.play();
            }
            return;
          }
        }
      } catch (err) {
        console.warn("Fallo al usar Gemini TTS, aplicando fallback a Web Speech API:", err);
      }
    }

    // Fallback: Web Speech API nativa
    if ('speechSynthesis' in window) {
      window.speechSynthesis.cancel(); // Cancelar locuciones previas
      const cleanMsg = textToSpeak.replace(/[#*`_]/g, '');
      const utterance = new SpeechSynthesisUtterance(cleanMsg);
      
      // Buscar una voz masculina madura en español si está disponible
      const voices = window.speechSynthesis.getVoices();
      const spanishVoice = voices.find(v => v.lang.startsWith('es') && (v.name.toLowerCase().includes('google') || v.name.toLowerCase().includes('microsoft')));
      if (spanishVoice) utterance.voice = spanishVoice;
      
      utterance.pitch = 0.8; // Tono más bajo para dar gravedad (voz madura de 60 años)
      utterance.rate = 0.95; // Velocidad ligeramente pausada académica

      utterance.onstart = () => setAudioPlaying(true);
      utterance.onend = () => setAudioPlaying(false);
      utterance.onerror = () => setAudioPlaying(false);

      window.speechSynthesis.speak(utterance);
    }
  };

  // Convertidor auxiliar de PCM16 a WAV para reproducción en navegador
  const pcmToWav = (pcmBuffer, sampleRate) => {
    const buffer = new ArrayBuffer(44 + pcmBuffer.byteLength);
    const view = new DataView(buffer);
    
    const writeString = (view, offset, string) => {
      for (let i = 0; i < string.length; i++) {
        view.setUint8(offset + i, string.charCodeAt(i));
      }
    };

    writeString(view, 0, 'RIFF');
    view.setUint32(4, 36 + pcmBuffer.byteLength, true);
    writeString(view, 8, 'WAVE');
    writeString(view, 12, 'fmt ');
    view.setUint32(16, 16, true);
    view.setUint16(20, 1, true); // PCM sin compresión
    view.setUint16(22, 1, true); // Monofónico
    view.setUint32(24, sampleRate, true);
    view.setUint32(28, sampleRate * 2, true); // Byte rate (SampleRate * 2 bytes por muestra)
    view.setUint16(32, 2, true); // Block align
    view.setUint16(34, 16, true); // 16 bits
    writeString(view, 36, 'data');
    view.setUint32(40, pcmBuffer.byteLength, true);
    
    const pcmView = new DataView(pcmBuffer);
    for (let i = 0; i < pcmBuffer.byteLength; i++) {
      view.setUint8(44 + i, pcmView.getUint8(i));
    }
    
    return new Blob([view], { type: 'audio/wav' });
  };

  const stopAudio = () => {
    if (audioRef.current) {
      audioRef.current.pause();
    }
    if ('speechSynthesis' in window) {
      window.speechSynthesis.cancel();
    }
    setAudioPlaying(false);
  };

  // --- RECONOCIMIENTO DE VOZ (STT) ---
  const handleVoiceInput = () => {
    if (!speechSupported) return;

    if (isListening) {
      setIsListening(false);
      return;
    }

    const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
    const recognition = new SpeechRecognition();
    recognition.lang = 'es-ES';
    recognition.interimResults = false;
    recognition.maxAlternatives = 1;

    recognition.onstart = () => {
      setIsListening(true);
    };

    recognition.onresult = (event) => {
      const speechToText = event.results[0][0].transcript;
      setInputText(speechToText);
    };

    recognition.onerror = (event) => {
      console.error("Error en reconocimiento de voz: ", event.error);
      setIsListening(false);
    };

    recognition.onend = () => {
      setIsListening(false);
    };

    recognition.start();
  };

  // --- RESPUESTA A EVALUACIÓN CONCEPTUAL ---
  const submitQuizAnswer = async () => {
    if (!extractedQuiz.userAnswer.trim()) return;

    setIsLoading(true);
    const evaluationPrompt = `
El profesor formuló la siguiente pregunta de evaluación biológica: "${extractedQuiz.question}"
El alumno respondió: "${extractedQuiz.userAnswer}"

Por favor, actúa como el sabio y respetuoso BioMentor AI (60 años, profesor universitario de biología). Evalúa la respuesta del alumno de manera constructiva, indicando si es correcta, parcialmente correcta o incorrecta. Explica con rigor científico por qué y complementa su conocimiento con un ejemplo natural estimulante. Sé breve y didáctico (máximo 6 líneas).
`;

    try {
      const evaluationResponse = await callGeminiAPI(evaluationPrompt, "Eres BioMentor AI, evalúa con amabilidad y rigor científico.");
      setExtractedQuiz(prev => ({
        ...prev,
        quizFeedback: evaluationResponse
      }));
    } catch (error) {
      console.error(error);
      setExtractedQuiz(prev => ({
        ...prev,
        quizFeedback: "Excelente esfuerzo. Recuerda que en biología, los detalles moleculares definen los procesos. ¡Sigue investigando!"
      }));
    } finally {
      setIsLoading(false);
    }
  };

  const handleLibraryTopicClick = (topicPrompt) => {
    setInputText(topicPrompt);
    setActiveTab('chat');
  };

  const clearChatHistory = () => {
    setMessages([
      {
        id: 'welcome',
        role: 'assistant',
        text: "¡Historial de laboratorio reiniciado! ¿Qué nuevo enigma de las ciencias biológicas abordaremos hoy, colega?",
        timestamp: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })
      }
    ]);
    setExtractedQuiz({
      summary: ["Exploración limpia iniciada."],
      question: "¿Deseas formular una pregunta sobre citología, evolución o biodiversidad?",
      userAnswer: "",
      quizFeedback: null
    });
  };

  return (
    <div className={`min-h-screen flex flex-col transition-all duration-500 font-sans ${isLightMode ? 'bg-stone-100 text-stone-900' : 'bg-stone-950 text-stone-100'}`}>
      <audio ref={audioRef} onEnded={() => setAudioPlaying(false)} className="hidden" />

      {/* --- ENCABEZADO "ANIMAL KINGDOM SCIENTIFIC" --- */}
      <header className="border-b border-emerald-800/30 bg-emerald-950/40 backdrop-blur-md px-6 py-4 sticky top-0 z-50 flex flex-wrap items-center justify-between shadow-lg">
        <div className="flex items-center space-x-3">
          <div className="bg-emerald-800 p-2.5 rounded-xl border border-emerald-500/30 flex items-center justify-center shadow-emerald-900/50 shadow-md">
            <Leaf className="h-6 w-6 text-emerald-300 animate-pulse" />
          </div>
          <div>
            <h1 className="text-xl font-bold tracking-tight text-emerald-400 flex items-center gap-2">
              BioMentor AI <span className="text-xs bg-emerald-900 text-emerald-300 px-2.5 py-0.5 rounded-full border border-emerald-700 font-mono">v2.5</span>
            </h1>
            <p className="text-xs text-stone-400 italic">Tu guía inteligente para la investigación biológica</p>
          </div>
        </div>

        {/* SELECTOR DE ECOSISTEMA / MODO DE COLOR */}
        <div className="flex items-center space-x-4 mt-3 sm:mt-0">
          <div className="flex bg-stone-900/80 p-1 rounded-lg border border-stone-800 text-xs">
            {ECOSYSTEMS.map(eco => (
              <button
                key={eco.id}
                onClick={() => {
                  setCurrentEcosystem(eco);
                  setIsLightMode(eco.id === 'light');
                }}
                className={`px-3 py-1.5 rounded-md transition-all ${currentEcosystem.id === eco.id ? 'bg-emerald-800 text-white shadow-md' : 'text-stone-400 hover:text-stone-200'}`}
              >
                {eco.name}
              </button>
            ))}
          </div>

          <button 
            onClick={clearChatHistory}
            title="Reiniciar Laboratorio"
            className="p-2 rounded-lg bg-stone-900 border border-stone-800 text-stone-400 hover:text-emerald-400 transition-colors"
          >
            <RotateCcw className="h-4 w-4" />
          </button>
        </div>
      </header>

      {/* --- CUERPO PRINCIPAL --- */}
      <main className="flex-1 max-w-7xl w-full mx-auto p-4 lg:p-6 grid grid-cols-1 lg:grid-cols-12 gap-6 items-stretch">
        
        {/* COLUMNA IZQUIERDA (4 COLS): AVATAR DEL DOCENTE Y NAVEGACIÓN */}
        <div className="lg:col-span-4 flex flex-col space-y-6">
          
          {/* PERFIL DEL BIOMENTOR (EL BÚHO SABIO) */}
          <div className={`p-6 rounded-2xl border ${isLightMode ? 'bg-white border-stone-200' : 'bg-stone-900/40 border-stone-800'} shadow-xl flex flex-col items-center text-center relative overflow-hidden`}>
            {/* Fondo decorativo estilizado */}
            <div className="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-emerald-800 via-emerald-500 to-amber-600" />
            
            {/* AVATAR SVG DETALLADO (BÚHO SABIO DEL BOSQUE) */}
            <div className="w-32 h-32 relative mb-4 mt-2 bg-emerald-950/20 rounded-full p-2 border-2 border-emerald-700/40 flex items-center justify-center animate-float">
              <svg viewBox="0 0 100 100" className="w-full h-full text-emerald-600">
                {/* Orejas de Búho */}
                <path d="M25,25 L15,10 L35,20 Z" fill="#2E7D32" />
                <path d="M75,25 L85,10 L65,20 Z" fill="#2E7D32" />
                {/* Cabeza y cuerpo */}
                <circle cx="50" cy="50" r="35" fill="#1B5E20" />
                {/* Plumaje del pecho */}
                <path d="M35,65 Q50,85 65,65 Q50,75 35,65 Z" fill="#6D4C41" />
                <path d="M40,55 Q50,70 60,55 Q50,62 40,55 Z" fill="#A1887F" />
                {/* Platos oculares gigantes blancos */}
                <circle cx="37" cy="40" r="14" fill="#F5F5DC" />
                <circle cx="63" cy="40" r="14" fill="#F5F5DC" />
                {/* Iris marrón */}
                <circle cx="37" cy="40" r="8" fill="#5D4037" />
                <circle cx="63" cy="40" r="8" fill="#5D4037" />
                {/* Pupilas negras con brillo */}
                <circle cx="37" cy="40" r="4" fill="#000" />
                <circle cx="63" cy="40" r="4" fill="#000" />
                <circle cx="39" cy="38" r="1" fill="#fff" />
                <circle cx="65" cy="38" r="1" fill="#fff" />
                {/* Gafas de científico */}
                <circle cx="37" cy="40" r="15" fill="none" stroke="#FFB300" strokeWidth="2.5" />
                <circle cx="63" cy="40" r="15" fill="none" stroke="#FFB300" strokeWidth="2.5" />
                <line x1="52" y1="40" x2="48" y2="40" stroke="#FFB300" strokeWidth="3" />
                {/* Pico naranja */}
                <polygon points="50,45 46,55 54,55" fill="#FF8F00" />
                {/* Cejas pobladas de sabio */}
                <path d="M22,25 Q35,23 45,29" fill="none" stroke="#F5F5DC" strokeWidth="4" strokeLinecap="round" />
                <path d="M78,25 Q65,23 55,29" fill="none" stroke="#F5F5DC" strokeWidth="4" strokeLinecap="round" />
              </svg>
              {audioPlaying && (
                <div className="absolute -bottom-1 bg-emerald-600 text-white text-xs px-2 py-0.5 rounded-full flex items-center gap-1 border border-emerald-400 animate-bounce">
                  <span className="w-1.5 h-1.5 bg-white rounded-full animate-ping"></span>
                  Hablando
                </div>
              )}
            </div>

            <h2 className="text-lg font-bold text-emerald-400">Profesor BioMentor AI</h2>
            <p className="text-xs text-stone-400 px-4 mt-1">
              "La naturaleza no hace nada en vano, cada orgánulo y ecosistema guarda un secreto esperando ser descrito científicamente."
            </p>

            {/* CONTROLES DE AUDIO DIRECTOS */}
            <div className="mt-4 flex space-x-2">
              {audioPlaying ? (
                <button 
                  onClick={stopAudio}
                  className="px-4 py-2 bg-red-950/80 text-red-300 border border-red-800 rounded-xl text-xs flex items-center gap-2 hover:bg-red-900 transition-colors"
                >
                  <VolumeX className="h-4 w-4" /> Detener Voz
                </button>
              ) : (
                <button 
                  onClick={() => speakText(messages[messages.length - 1]?.text)}
                  className="px-4 py-2 bg-emerald-900/60 text-emerald-300 border border-emerald-700/50 rounded-xl text-xs flex items-center gap-2 hover:bg-emerald-900 transition-colors"
                >
                  <Volume2 className="h-4 w-4" /> Escuchar Último
                </button>
              )}
            </div>
          </div>

          {/* MENÚ DE PESTAÑAS */}
          <div className="grid grid-cols-3 bg-stone-900/80 p-1.5 rounded-xl border border-stone-800">
            <button
              onClick={() => setActiveTab('chat')}
              className={`py-2 text-xs font-medium rounded-lg transition-all ${activeTab === 'chat' ? 'bg-emerald-800 text-white' : 'text-stone-400 hover:text-stone-200'}`}
            >
              Laboratorio
            </button>
            <button
              onClick={() => setActiveTab('library')}
              className={`py-2 text-xs font-medium rounded-lg transition-all ${activeTab === 'library' ? 'bg-emerald-800 text-white' : 'text-stone-400 hover:text-stone-200'}`}
            >
              Biblioteca
            </button>
            <button
              onClick={() => setActiveTab('feedback')}
              className={`py-2 text-xs font-medium rounded-lg transition-all ${activeTab === 'feedback' ? 'bg-emerald-800 text-white' : 'text-stone-400 hover:text-stone-200'}`}
            >
              Evaluación
            </button>
          </div>

          {/* PANEL DE DETALLE CONFIGURATION */}
          <div className={`p-5 rounded-2xl border ${isLightMode ? 'bg-white border-stone-200' : 'bg-stone-900/40 border-stone-800'} hidden lg:block shadow-md`}>
            <h3 className="text-xs font-bold text-stone-400 uppercase tracking-wider mb-3 flex items-center gap-2">
              <Sliders className="h-4 w-4 text-emerald-400" /> Nivel de Profundidad Científica
            </h3>
            <div className="space-y-2">
              {[
                { id: 'brief', title: 'Breve (Clases de Repaso)', desc: 'Respuestas directas de máximo 5 líneas.' },
                { id: 'normal', title: 'Normal (Estándar Académico)', desc: 'Explicaciones lógicas y estructuradas.' },
                { id: 'detailed', title: 'Detallado (Tesis/Investigación)', desc: 'Análisis molecular completo, ejemplos y referencias.' }
              ].map(lvl => (
                <button
                  key={lvl.id}
                  onClick={() => setResponseLevel(lvl.id)}
                  className={`w-full text-left p-2.5 rounded-xl border transition-all ${responseLevel === lvl.id ? 'bg-emerald-950/60 border-emerald-500/50 text-white shadow-sm' : 'border-transparent text-stone-400 hover:bg-stone-800/30 hover:text-stone-200'}`}
                >
                  <p className="text-xs font-bold flex items-center gap-1.5 text-emerald-300">
                    <span className={`w-2 h-2 rounded-full ${responseLevel === lvl.id ? 'bg-emerald-400' : 'bg-stone-600'}`}></span>
                    {lvl.title}
                  </p>
                  <p className="text-[10px] text-stone-400 mt-0.5 ml-3.5">{lvl.desc}</p>
                </button>
              ))}
            </div>
          </div>
        </div>

        {/* COLUMNA DERECHA (8 COLS): CONTENIDO SEGÚN LA PESTAÑA */}
        <div className="lg:col-span-8 flex flex-col space-y-6">
          
          {/* VISTA DE CHAT (LABORATORIO DE INVESTIGACIÓN) */}
          {activeTab === 'chat' && (
            <div className={`flex-1 flex flex-col rounded-2xl border ${isLightMode ? 'bg-white border-stone-200' : 'bg-stone-900/30 border-stone-800'} overflow-hidden min-h-[500px] shadow-2xl`}>
              {/* Barra superior de estado */}
              <div className="px-5 py-3 border-b border-stone-800/40 bg-stone-900/60 flex justify-between items-center text-xs">
                <span className="flex items-center gap-1.5 text-stone-400">
                  <span className="w-2.5 h-2.5 rounded-full bg-emerald-500 animate-ping"></span>
                  Conexión directa: <strong className="text-emerald-400">Bases de datos indexadas</strong>
                </span>
                <span className="text-[10px] text-stone-400 italic">Prepara tu pregunta científica</span>
              </div>

              {/* Mensajes */}
              <div className="flex-1 overflow-y-auto p-5 space-y-4 max-h-[480px]">
                {messages.map((msg, index) => (
                  <div key={msg.id || index} className={`flex ${msg.role === 'user' ? 'justify-end' : 'justify-start'}`}>
                    <div className={`max-w-[85%] rounded-2xl p-4 shadow-md ${
                      msg.role === 'user' 
                        ? 'bg-emerald-800 text-white rounded-br-none' 
                        : isLightMode ? 'bg-stone-50 border border-stone-200 text-stone-800 rounded-bl-none' : 'bg-stone-900/80 border border-emerald-950 text-stone-200 rounded-bl-none'
                    }`}>
                      {/* Cabecera del mensaje */}
                      <div className="flex justify-between items-center mb-1 pb-1 border-b border-emerald-950/10 text-[10px] opacity-75">
                        <span className="font-bold tracking-wider uppercase">
                          {msg.role === 'user' ? 'Tú (Investigador)' : 'Prof. BioMentor'}
                        </span>
                        <span>{msg.timestamp}</span>
                      </div>

                      {/* Texto del mensaje */}
                      <div className="text-sm leading-relaxed whitespace-pre-line prose prose-invert">
                        {msg.text}
                      </div>

                      {/* Botón rápido de reproducción para el mensaje individual */}
                      {msg.role === 'assistant' && (
                        <div className="mt-3 pt-2 border-t border-stone-800/20 flex justify-end">
                          <button 
                            onClick={() => speakText(msg.text)}
                            className="p-1 hover:bg-emerald-900/40 rounded text-emerald-400 text-xs flex items-center gap-1"
                            title="Escuchar locución de este bloque"
                          >
                            <Volume2 className="h-3.5 w-3.5" /> <span className="text-[10px]">Escuchar</span>
                          </button>
                        </div>
                      )}
                    </div>
                  </div>
                ))}
                {isLoading && (
                  <div className="flex justify-start">
                    <div className="bg-stone-900/50 border border-stone-800 rounded-2xl rounded-bl-none p-4 max-w-[80%] flex items-center space-x-3">
                      <div className="flex space-x-1">
                        <div className="w-2 h-2 bg-emerald-400 rounded-full animate-bounce" style={{ animationDelay: '0ms' }}></div>
                        <div className="w-2 h-2 bg-emerald-400 rounded-full animate-bounce" style={{ animationDelay: '150ms' }}></div>
                        <div className="w-2 h-2 bg-emerald-400 rounded-full animate-bounce" style={{ animationDelay: '300ms' }}></div>
                      </div>
                      <span className="text-xs text-stone-400 italic font-mono">Buscando fuentes, revisando bibliografía académica...</span>
                    </div>
                  </div>
                )}
                <div ref={messagesEndRef} />
              </div>

              {/* Controles de Nivel de Respuesta móviles */}
              <div className="px-4 py-2 bg-stone-950/80 border-t border-stone-900 flex lg:hidden items-center justify-between text-xs overflow-x-auto gap-2">
                <span className="text-stone-400 whitespace-nowrap font-bold">Nivel de detalle:</span>
                <div className="flex gap-1.5">
                  {['brief', 'normal', 'detailed'].map(l => (
                    <button
                      key={l}
                      onClick={() => setResponseLevel(l)}
                      className={`px-3 py-1 rounded-full text-[10px] capitalize ${responseLevel === l ? 'bg-emerald-800 text-white' : 'bg-stone-900 text-stone-400'}`}
                    >
                      {l}
                    </button>
                  ))}
                </div>
              </div>

              {/* Panel de entrada de texto e interactividad */}
              <div className="p-4 border-t border-stone-800/40 bg-stone-950/90 flex items-center space-x-2">
                <button
                  onClick={handleVoiceInput}
                  className={`p-3 rounded-xl border transition-all ${isListening ? 'bg-red-950 border-red-500 text-red-400 animate-pulse' : 'bg-stone-900 border-stone-800 text-stone-300 hover:text-emerald-400'}`}
                  title={speechSupported ? "Hablar por micrófono" : "Dictado no soportado en tu navegador"}
                  disabled={!speechSupported}
                >
                  {isListening ? <MicOff className="h-5 w-5" /> : <Mic className="h-5 w-5" />}
                </button>

                <input
                  type="text"
                  value={inputText}
                  onChange={(e) => setInputText(e.target.value)}
                  onKeyDown={(e) => e.key === 'Enter' && handleSendMessage()}
                  placeholder={isListening ? "Escuchando... habla ahora" : "Pregunta sobre filogenia, orgánulos, enzimas..."}
                  className="flex-1 bg-stone-900 border border-stone-800 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-emerald-500 text-stone-100"
                />

                <button
                  onClick={() => handleSendMessage()}
                  disabled={isLoading || !inputText.trim()}
                  className="bg-emerald-700 hover:bg-emerald-600 disabled:bg-stone-800 disabled:text-stone-600 text-white p-3 rounded-xl transition-all shadow-md flex items-center justify-center"
                >
                  <Send className="h-5 w-5" />
                </button>
              </div>
            </div>
          )}

          {/* VISTA DE BIBLIOTECA (PREGUNTAS PREDISEÑADAS) */}
          {activeTab === 'library' && (
            <div className={`p-6 rounded-2xl border ${isLightMode ? 'bg-white border-stone-200' : 'bg-stone-900/30 border-stone-800'} space-y-6 shadow-xl`}>
              <div>
                <h3 className="text-lg font-bold text-emerald-400 flex items-center gap-2">
                  <BookOpen className="h-5 w-5 text-emerald-400" /> Biblioteca de Especialidades Biológicas
                </h3>
                <p className="text-xs text-stone-400 mt-1">Haz clic en cualquiera de estas temáticas para cargar una pregunta de investigación científica sugerida por el mentor:</p>
              </div>

              <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                {BIOLOGY_BRANCHES.map(branch => (
                  <button
                    key={branch.id}
                    onClick={() => handleLibraryTopicClick(branch.prompt)}
                    className="p-4 rounded-xl border border-stone-800/80 bg-stone-900/60 hover:bg-emerald-950/30 hover:border-emerald-700/50 text-left transition-all group flex flex-col justify-between"
                  >
                    <div>
                      <div className="flex items-center justify-between mb-2">
                        <span className="text-2xl">{branch.icon}</span>
                        <ChevronRight className="h-4 w-4 text-stone-500 group-hover:text-emerald-400 transition-colors" />
                      </div>
                      <h4 className="text-sm font-bold text-stone-200 group-hover:text-emerald-300 transition-colors">{branch.name}</h4>
                      <p className="text-xs text-stone-400 mt-1 line-clamp-2 italic">"{branch.prompt}"</p>
                    </div>
                  </button>
                ))}
              </div>

              <div className="bg-emerald-950/20 border border-emerald-900/40 p-4 rounded-xl flex items-start gap-3">
                <Info className="h-5 w-5 text-emerald-400 shrink-0 mt-0.5" />
                <div className="text-xs text-stone-300">
                  <strong className="text-emerald-400 block mb-1">Nota del Profesor:</strong>
                  Puedes editar y expandir las preguntas recomendadas una vez que se carguen en la caja de texto. ¡Añade tu propio enfoque experimental o cambia el nivel de detalle!
                </div>
              </div>
            </div>
          )}

          {/* VISTA DE EVALUACIÓN INTERACTIVA (RETROALIMENTACIÓN) */}
          {activeTab === 'feedback' && (
            <div className={`p-6 rounded-2xl border ${isLightMode ? 'bg-white border-stone-200' : 'bg-stone-900/30 border-stone-800'} space-y-6 shadow-xl`}>
              <div className="flex items-center justify-between">
                <div>
                  <h3 className="text-lg font-bold text-emerald-400 flex items-center gap-2">
                    <Award className="h-5 w-5 text-emerald-400" /> Panel de Retroalimentación y Aprendizaje
                  </h3>
                  <p className="text-xs text-stone-400 mt-1">BioMentor AI extrae el contenido de la última respuesta para evaluar tu comprensión intelectual.</p>
                </div>
                <span className="bg-emerald-900/50 text-emerald-300 border border-emerald-800 text-[10px] font-mono px-2.5 py-1 rounded-md">Interactivo</span>
              </div>

              {/* Tarjeta de Puntos Clave */}
              <div className="p-4 rounded-xl bg-stone-900/60 border border-stone-800">
                <h4 className="text-xs font-bold text-stone-400 uppercase tracking-wider mb-2 flex items-center gap-1.5">
                  <CheckCircle2 className="h-4 w-4 text-emerald-400" /> Puntos Clave del Último Tema
                </h4>
                <ul className="space-y-1.5">
                  {extractedQuiz.summary.map((point, index) => (
                    <li key={index} className="text-xs text-stone-300 flex items-start gap-2">
                      <span className="text-emerald-500 font-bold mt-0.5">•</span>
                      <span>{point}</span>
                    </li>
                  ))}
                </ul>
              </div>

              {/* Caja de Evaluación Actual */}
              <div className="p-5 rounded-xl border border-amber-900/30 bg-amber-950/10 space-y-4">
                <div className="flex items-center gap-2 text-amber-400">
                  <HelpCircle className="h-5 w-5 text-amber-500 animate-bounce" />
                  <span className="text-sm font-bold">Pregunta Formulada por el Mentor:</span>
                </div>
                <p className="text-xs text-stone-200 italic font-medium leading-relaxed bg-stone-900/40 p-3 rounded-lg border border-stone-800">
                  {extractedQuiz.question}
                </p>

                {/* Caja de respuesta de texto */}
                <div className="space-y-2">
                  <label className="text-[10px] text-stone-400 uppercase font-bold block">Tu Respuesta Académica</label>
                  <textarea
                    rows={3}
                    value={extractedQuiz.userAnswer}
                    onChange={(e) => setExtractedQuiz(prev => ({ ...prev, userAnswer: e.target.value }))}
                    placeholder="Escribe tu hipótesis o respuesta científica para que el mentor la califique..."
                    className="w-full bg-stone-900 border border-stone-800 rounded-xl p-3 text-xs focus:outline-none focus:border-amber-500 text-stone-100"
                  />
                </div>

                <div className="flex justify-end">
                  <button
                    onClick={submitQuizAnswer}
                    disabled={isLoading || !extractedQuiz.userAnswer.trim()}
                    className="bg-amber-600 hover:bg-amber-500 disabled:bg-stone-800 disabled:text-stone-600 text-stone-950 font-bold text-xs px-5 py-2.5 rounded-xl transition-all shadow-md flex items-center gap-1.5"
                  >
                    <Sparkles className="h-3.5 w-3.5" /> Evaluar Respuesta
                  </button>
                </div>
              </div>

              {/* Feedback de la Evaluación de Gemini */}
              {extractedQuiz.quizFeedback && (
                <div className="p-4 rounded-xl border border-emerald-900/40 bg-emerald-950/10 space-y-2 animate-fadeIn">
                  <div className="flex items-center gap-1.5 text-emerald-400">
                    <BookMarked className="h-4 w-4" />
                    <span className="text-xs font-bold">Calificación del Mentor:</span>
                  </div>
                  <p className="text-xs text-stone-200 leading-relaxed whitespace-pre-line bg-stone-900/30 p-3 rounded-lg">
                    {extractedQuiz.quizFeedback}
                  </p>
                </div>
              )}
            </div>
          )}

        </div>
      </main>

      {/* --- PIE DE PÁGINA --- */}
      <footer className="mt-auto border-t border-stone-800/40 bg-stone-950/60 p-4 text-center text-[10px] text-stone-500 flex flex-col sm:flex-row items-center justify-between px-6">
        <span>© 2026 BioMentor AI - Diseñado bajo estándares académicos estrictos y pedagogía científica.</span>
        <span className="text-emerald-500 font-mono mt-1 sm:mt-0">Ecosistema actual: {currentEcosystem.name}</span>
      </footer>
    </div>
  );
}